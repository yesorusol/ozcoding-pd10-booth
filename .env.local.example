# Supabase Storage credentials — required for /api/captures to work.
# Get these from: https://supabase.com/dashboard/project/_/settings/api
#
#   1. Create a new Supabase project (recommend region: Northeast Asia / Seoul)
#   2. Storage → New bucket → name "captures" → check "Public bucket"
#   3. Project Settings → API → copy "Project URL" into SUPABASE_URL
#   4. Project Settings → API → reveal & copy "service_role" key (NOT anon!)
#      into SUPABASE_SERVICE_ROLE_KEY
#
# Copy this file to `.env.local` and fill in the real values. `.env.local` is
# gitignored — never commit your service_role key.

SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Random secret used to authenticate the Vercel cron that purges captures
# older than 24h. Generate with: `openssl rand -hex 32`. Required in
# production; not used during `npm run dev`.
CRON_SECRET=replace-with-a-random-hex-string
